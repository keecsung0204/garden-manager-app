generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Area {
  id        Int     @id @default(autoincrement())
  areaCode  String  @unique
  name      String

  plants    Plant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlantCategory {
  id           Int     @id @default(autoincrement())
  categoryCode String  @unique
  name         String

  plants       Plant[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plant {
  id              Int     @id @default(autoincrement())
  plantCode       String  @unique

  areaId          Int?
  area            Area?   @relation(fields: [areaId], references: [id])

  categoryId      Int?
  category        PlantCategory? @relation(fields: [categoryId], references: [id])

  plantName       String
  scientificName  String?
  identifyStatus  IdentifyStatus @default(Unknown)
  statusId        Int?
  status          PlantStatus? @relation(fields: [statusId], references: [id])

  notes           PlantNote[]
  photos          PlantPhoto[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PlantNote {
  id        Int      @id @default(autoincrement())

  plantId   Int
  plant     Plant    @relation(fields: [plantId], references: [id])

  noteDate  DateTime @default(now())
  noteType  String?

  noteTypeId Int?
  noteTypeRef NoteType? @relation(fields: [noteTypeId], references: [id])

  content   String
  photos    PlantPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NoteType {
  id           Int      @id @default(autoincrement())
  typeCode     String   @unique
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)

  notes        PlantNote[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PlantStatus {
  id           Int      @id @default(autoincrement())
  statusCode   String   @unique
  name         String
  description  String?
  displayOrder Int      @default(0)

  plants       Plant[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PlantPhoto {
  id        Int      @id @default(autoincrement())

  plantId   Int
  plant     Plant    @relation(fields: [plantId], references: [id])

  noteId    Int
  note      PlantNote @relation(fields: [noteId], references: [id])

  fileName  String
  filePath  String
  caption   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum IdentifyStatus {
  Unknown
  Tentative
  Confirmed
}
